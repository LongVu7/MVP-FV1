// !--- Student table ---! //
model Student {
  id       Int    @id @default(autoincrement())
  fullName String @map("full_name") @db.VarChar(255)

  gender String? @db.VarChar(20)

  email String? @db.VarChar(255)

  mobile String? @unique @db.VarChar(20)

  otherPhone String? @map("other_phone") @db.VarChar(20)

  birthDate DateTime? @map("birth_date") @db.Date

  parentPhone String? @map("parent_phone") @db.VarChar(20)

  primaryAddressCity String? @map("primary_address_city") @db.VarChar(255)

  schoolId Int?    @map("school_id")
  school   School? @relation(fields: [schoolId], references: [id])

  specializedRegisterId Int?                @unique @map("specialized_register_id")
  specializedRegister   SpecializedRegister? @relation(fields: [specializedRegisterId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  inquiry Inquiry?

  @@index([mobile])
  @@index([schoolId])
  @@map("student")
}