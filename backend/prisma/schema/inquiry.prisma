// !--- Inquiry table ---! //
model Inquiry {
  id Int @id @default(autoincrement())

  assignedToId Int? @map("assigned_to_id")

  statusGeneral String? @map("status_general") @db.VarChar(100)

  statusDetail String? @map("status_detail") @db.VarChar(255)

  leadSource String? @map("lead_source") @db.VarChar(255)

  firstContactSource String? @map("first_contact_source") @db.VarChar(255)

  priority String? @db.VarChar(50)

  description String?

  dataReceived DateTime? @map("data_received") @db.Date

  dataSource String? @map("data_source") @db.VarChar(255)

  sourceDataId Int?        @map("source_data_id")
  sourceData   SourceData? @relation(fields: [sourceDataId], references: [id])

  regional String? @db.VarChar(10)

  groupTele String? @map("group_tele") @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  assignedTo Account? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  studentId Int?     @unique @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  campaignRecipients CampaignRecipient[]


  @@index([createdAt])
  @@index([sourceDataId])
  @@map("inquiry")
}

enum LeadSource {
  online
  direct
  database
  referal
  internal
  onlineMass
  resonance
  other
}

enum StatusGeneral {
  new
  assigned
  inProcess
  converted
  dead
}

enum StatusDetail {
  interested
  considered
  contactLater
  kbm
  notContacted
  applied
}

enum FirstContactSource {
  tele
  walkIn
  online
  incomingPhone
}

enum DataSource {
  webGame
  holland
  roadShowCity
  roadShowProvince
  acquireCity
  acquireProvince
  cityInquiry
  provinceInquiry
  partnership
  income
  openDayInquiry
  eventInquiry
  activeContact
}

enum Regional {
  kv1
  kv2
  kv3
  kv4
  kv5
  kv6
}

